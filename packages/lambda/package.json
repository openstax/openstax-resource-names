{
  "name": "@project/lambdas",
  "version": "1.0.0",
  "dependencies": {
    "@openstax/open-search-client": "^0.1.0-build.8",
    "@openstax/orn-locator": "^1.4.0",
    "@openstax/ts-utils": "1.48.1",
    "aws-sdk": "^2.1145.0",
    "aws-xray-sdk": "^3.6.0",
    "body-parser": "^1.19.2",
    "node-fetch": "^2.7.0",
    "path-to-regexp": "^6.2.0",
    "query-string": "^7.1.1",
    "url": "^0.11.0",
    "zod": "^4.0.15"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/aws-lambda": "^8.10.92",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.2.0",
    "@types/node-fetch": "^2.6.11",
    "@types/supertest": "^2.0.12",
    "builtin-modules": "^3.2.0",
    "cspell": "^6.12.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import-x": "^4.15.0",
    "eslint-plugin-jest": "^28.11.0",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "nock": "^13.2.9",
    "npm-run-all": "^4.1.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.3.0",
    "tsc-watch": "^7.2.0",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.48.0",
    "webpack": "^5.69.1",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^4.9.2",
    "yargs": "^17.5.1"
  },
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "archive": "npm run archive:bundle && npm run archive:zip",
    "archive:bundle": "webpack --mode production",
    "archive:clean": "npm run clean && npm run archive",
    "archive:zip": "./script/bundle-functions.bash",
    "build": "./script/build.bash",
    "build:clean": "npm run clean && npm run build",
    "ci": "CI=true npm-run-all ci:*",
    "ci:lint": "eslint --max-warnings=0 .",
    "ci:spelling": "git ls-files | cspell -c ../../cspell.json --file-list stdin",
    "ci:test": "jest --coverage",
    "ci:typecheck": "tsc --noEmit",
    "clean": "rm -rf dist build",
    "coverage-report": "open coverage/index.html",
    "data:clean": "find data/ -maxdepth 1 -type f -delete",
    "data:reset": "npm run data:clean && npm run data:seed",
    "data:seed": "cp -n ./data/seeds/* ./data/ || true",
    "start": "./script/build.bash --watch",
    "test": "jest"
  }
}
