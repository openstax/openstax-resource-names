{
  "name": "@openstax/orn-locator",
  "version": "1.4.1",
  "browser": "dist/index.browser.js",
  "dependencies": {
    "@openstax/open-search-client": "^0.1.0-build.8",
    "cross-fetch": "^3.1.5",
    "domutils": "^3.0.1",
    "htmlparser2": "^8.0.1",
    "node-fetch": "^2.7.0",
    "path-to-regexp": "^6.2.0",
    "tiny-async-pool": "^1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.2.0",
    "@types/node-fetch": "^2.6.11",
    "@types/tiny-async-pool": "1",
    "cspell": "^10.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import-x": "^4.15.0",
    "eslint-plugin-jest": "^28.11.0",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.4.1",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.48.0",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0",
    "yargs": "^17.5.1"
  },
  "exports": {
    ".": {
      "node": "./dist/index.nodejs.js",
      "browser": "./dist/index.browser.js",
      "default": "./dist/index.js"
    },
    "./resolve": {
      "node": "./dist/resolve.nodejs.js",
      "browser": "./dist/resolve.browser.js",
      "default": "./dist/resolve.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "dist/index.nodejs.js",
  "scripts": {
    "build": "./script/build.bash",
    "build:clean": "npm run clean && npm run build",
    "build:example": "npm run build && webpack -c ./example/webpack.config.js",
    "ci": "CI=true npm-run-all ci:*",
    "ci:build": "npm run build -- --clean",
    "ci:lint": "eslint --max-warnings=0 .",
    "ci:spelling": "git ls-files | cspell -c ../../cspell.json --file-list stdin",
    "ci:test": "jest --coverage",
    "ci:typecheck": "tsc --noEmit",
    "clean": "rm -rf dist build",
    "coverage-report": "open coverage/index.html",
    "start": "./script/build.bash --watch",
    "test": "jest"
  },
  "types": "index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "dist/*",
        "dist/*.d.ts",
        "dist/*/index.d.ts"
      ]
    }
  }
}
