    "react-dom": "^17.0.2",
    "styled-components": "^5.3.5",
    "typescript": "5.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@project/lambdas": "1.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "cspell": "^6.12.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
