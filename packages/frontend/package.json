    "ci:typecheck": "tsc --noEmit",
    "clean": "rm -rf build",
    "coverage-report": "open coverage/index.html",
    "dev": "vite",
    "preview": "vite preview",
    "start": "./script/start.bash",
    "test": "vitest"
